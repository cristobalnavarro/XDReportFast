      <TextObject Name="mInfo1" Left="37.8" Top="18.9" Width="604.8" Height="37.8" CanGrow="true" Text="Este reporte demuestra como Harbour manipula el color y texto del titulo en tiempo de ejecucion." Font="Arial, 10pt"/>
      <TextObject Name="mInfo2" Left="37.8" Top="37.8" Width="718.2" Height="37.8" CanGrow="true" Text="//LANGUAGE:HARBOUR&#13;&#10;FUNCTION PageHeader1_OnBeforePrint( sender, e )&#13;&#10;   LOCAL oMemo&#13;&#10;   LOCAL cRet&#13;&#10;   // Acceso directo al reporte principal via hObject (inyectado)&#13;&#10;   IF oMemo != NIL&#13;&#10;      oMemo:FillColor := 255 // Rojo&#13;&#10;      oMemo:TextColor := 16777215 // Blanco&#13;&#10;      oMemo:Text := 'TITULO DINAMICO DESDE HARBOUR'&#13;&#10;      cRet := 'ONBEFOREPRINT'&#13;&#10;   ELSE&#13;&#10;      cRet := 'MEMO IS NIL'&#13;&#10;   ENDIF&#13;&#10;RETURN cRet" Font="Arial, 10pt"/>
