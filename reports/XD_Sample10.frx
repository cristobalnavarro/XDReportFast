namespace FastReport
{
  public class ReportScript
  {
    /* XD_START */
    // EXPOSED DATA SOURCES: Products, Customer, SubtotalPrice, TotalGeneral
    public dynamic XD_Report { get { return XDFastReportBridge.XDReportEngine._report; } }
    public dynamic XD_Engine { get { return XDFastReportBridge.XDReportEngine._report.Engine; } }
    public dynamic mMain { get { return XDFastReportBridge.XDReportEngine._report; } }
    public dynamic mEngine { get { return XDFastReportBridge.XDReportEngine._report.Engine; } }
    public dynamic Products { get { return new DynamicDataSource(XDFastReportBridge.XDReportEngine._report.GetDataSource(&quot;Products&quot;)); } }
    public dynamic Customer { get { return new DynamicDataSource(XDFastReportBridge.XDReportEngine._report.GetDataSource(&quot;Customer&quot;)); } }
    public dynamic SubtotalPrice { get { return XDFastReportBridge.XDReportEngine._report.GetTotalValue(&quot;SubtotalPrice&quot;); } }
    public dynamic TotalGeneral { get { return XDFastReportBridge.XDReportEngine._report.GetTotalValue(&quot;TotalGeneral&quot;); } }
    /* XD_END */

  }
}
